#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int main() {
	int N;
	scanf("%d", &N);
	char man[2005][21];
	int man_cnt = 0;

	strcpy(man[man_cnt++], "ChongChong"); // The array start with "ChongChong".

	for (int i = 0; i < N; i++) {
		char a1[21], a2[21];
		scanf("%s %s", a1, a2);
		int a1_is_dancing = 0;
		int a2_is_dancing = 0;

		for (int j = 0; j < man_cnt; j++) { // Check if either person is already in the 'man' list.
			if (strcmp(man[j], a1) == 0) a1_is_dancing = 1;
			if (strcmp(man[j], a2) == 0) a2_is_dancing = 1;
		}

		if (a1_is_dancing == 1 || a2_is_dancing == 1) { // If at least one person is dancing, the other person starts dancing too.
			if (a1_is_dancing == 0) strcpy(man[man_cnt++], a1);
			if (a2_is_dancing == 0) strcpy(man[man_cnt++], a2);
		}
	}
	printf("%d\n", man_cnt);
	return 0;
}
