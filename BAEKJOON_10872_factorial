#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int main() {
	int N;
	scanf("%d", &N);
	int sum = 1;
	for (int i = N; i > 0; i--) {
		sum *= i;
	}
	printf("%d\n", sum);
	return 0;
}
