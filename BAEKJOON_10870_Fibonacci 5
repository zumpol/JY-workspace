#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int Fibonacci(int n) {
	if (n <= 1) return n;
	return Fibonacci(n - 2) + Fibonacci(n - 1);
}

int main() {
	int n;
	scanf("%d", &n);
	printf("%d\n", Fibonacci(n));
	return 0;
}
