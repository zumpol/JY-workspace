#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int main() {
	int x, y, z;
	scanf("%d %d %d", &x, &y, &z);

	if (x == y && x == z) { // Invalid Expression : x == y == z
		printf("%d", 10000 + x * 1000);
	}
	else if (x == y || y == z) {
		printf("%d", 1000 + y * 100);
	}
	else if (x == z) {
		printf("%d", 1000 + x * 100);
	}
	else {
		if (x > y && x > z) {
			printf("%d", x * 100);
		}
		else if (y > x && y > z) {
			printf("%d", y * 100);
		}
		else {
			printf("%d", z * 100);
		}
	}
	return 0;
}
