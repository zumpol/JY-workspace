#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int main() {
	int N;
	char numbers[101];
	scanf("%d", &N);
	scanf("%s", numbers); // Read the entire sequence of numbers as a single string.
  
	int sum = 0;
	for (int i = 0; i < N; i++) {
		sum += (int)(numbers[i] - '0'); // Subtracting '0' from a character digit converts it into its corresponding integer value.
	}
  
	printf("%d", sum);
	return 0;
}
