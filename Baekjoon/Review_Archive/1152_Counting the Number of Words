#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int main() {
	char S[1000001];
	int cnt = 0;
	fgets(S, sizeof(S), stdin); // Read the input string including spaces.
  S[strcspn(S, "\n")] = '\0'; // Remove the trailing newline character(\n) by replacing it with a null terminator(\0).
    
	int len = strlen(S);
	for (int i = 0; i < len; i++) {
		if (S[i] != ' ') { // Skip spaces to process only valid characters and identify the beginning of each word.
			if (i == 0 || S[i - 1] == ' ') { // Count the character if it is the beginning of a word.
				cnt++;
			}
		}
	}
    
	printf("%d", cnt);
	return 0;
}
