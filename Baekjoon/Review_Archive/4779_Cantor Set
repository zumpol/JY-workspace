#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

void cantor(int N) {
	if (N == 0) { // If N is 0, print a hyphen(-) and stop recursion.
		printf("-");
		return 0;
	}

	cantor(N - 1); // 1. Print the left 1/3 part.
	
	for (int i = 0; i < pow(3, N - 1); i++) { // 2. Print the middle[3^(n-1) spaces].
		printf(" ");
	
	}
	cantor(N - 1); // 3. Print the right 1/3 part.
}

int main() {
	int N;
	while (scanf("%d", &N) == 1) { // Read input integers until the end of the file(EOF).
		cantor(N);
		printf("\n");
	}
	
	return 0;
}
