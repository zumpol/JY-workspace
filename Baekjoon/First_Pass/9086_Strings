#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int main() {
	int T;
	scanf("%d", &T);
    
	for (int i = 0; i < T; i++) {
		char s[1001];
		scanf("%s", s);
    	int len = strlen(s);
		printf("%c%c\n", s[0], s[len - 1]); // s[0] -> first character, s[len - 1] -> last character
    }
    
	return 0;
}
