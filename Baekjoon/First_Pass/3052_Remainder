#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int main() {
	int n[42] = { 0, }; // Remainder checklist[0 ~ 41]. "Initial" : 0
	int N, cnt = 0;
  
	for (int i = 0; i < 10; i++) {
		scanf("%d", &N);
		n[N % 42] = 1; // Set the value to 1 at the remainder's index. "Distinct" : 1
	}
  
	for (int i = 0; i <= 41; i++) {
		if (n[i] == 1) {
			cnt += 1; // Add if the value is 1.
		}
	}
  
	printf("%d", cnt);
	return 0;
}
