#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int main() {
	int N;
	float cnt = 0;
	scanf("%d", &N);
	int* score = (int*)malloc(sizeof(int) * N);
    
	for (int i = 0; i < N; i++) {
		scanf("%d", &score[i]);
	}
    
	int M = score[0]; // Initialize maximum score with the first element.
	for (int i = 0; i < N; i++) {
		if (score[i] > M) {
			M = score[i];
		}
		cnt += score[i]; // Add each score to the total sum.
	}
    
	printf("%f\n", (cnt * 100.0) / M / N); // How to calculate a new average.
	free(score);
	return 0;
}
