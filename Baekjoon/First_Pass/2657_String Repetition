#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int main() {
	int T, R;
	char S[21];
	scanf("%d", &T);
    
	for (int i = 0; i < T; i++) {
		scanf("%d %s", &R, S);
        int len = strlen(S);
		for (int j = 0; j < len; j++) { // Check each character in the string.
			for (int k = 0; k < R; k++) { // Repeat the current character R times.
				printf("%c", S[j]);
			}
		}
		printf("\n"); // Move to the next line for the next input.
	}
	return 0;
}
