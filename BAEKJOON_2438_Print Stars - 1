int main() {
	int N;
	scanf("%d", &N);

	for (int i = 1; i <= N; i++) {
		for (int n = 0; n < i; n++) {
			printf("*");
		}
		printf("\n"); // This line of code moved to ensure a newline after each row of stars.
	}
  return 0;
}
