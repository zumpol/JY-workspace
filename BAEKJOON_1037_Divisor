#define _CRT_SECURE_NO_WARNINGS
#define _USE_MATH_DEFINES
#define _CRT_MONSTDC_NO_DEPRECATE

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <string.h>
#include <ctype.h>
#include <limits.h>

int main() {
	int a;
	scanf("%d", &a);
	int max = 2, min = 1000000;

	for (int i = 0; i < a; i++) {
		int num;
		scanf("%d", &num);
		if(num < min) min = num;
		if(num > max) max = num;
	}

	printf("%d\n", min * max);
	return 0;
}
